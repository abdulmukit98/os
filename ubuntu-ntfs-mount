If no disks app then run command to get UUID

lsblk -f

start drive and collect uuid & mountpoint
=> If no mount point folder then create one

sudo mkdir -p "/media/abdulmukit/Faith"
sudo mkdir -p "/media/abdulmukit/New Dawn"


# <file system> <mount point>   <type>  <options>       <dump>  <pass>

UUID=B25C9ACD5C9A8C2B /media/abdul-mukit/Faith auto defaults 0 2
UUID=59E1D2FC2B9A84F5 /media/abdul-mukit/New\040Dawn ntfs-3g defaults,uid=1000,gid=1000,umask=0022,nofail 0 0
